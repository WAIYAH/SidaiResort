# Sidai Safari Dreams — Local Development Environment
# Copy this file to .env and adjust values

APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/sidai-safari-dreams/public
WEB_ROOT=/sidai-safari-dreams/public

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sidai_resort
DB_USER=root
DB_PASSWORD=

# Session (disable secure cookie for HTTP localhost)
SESSION_COOKIE_SECURE=false

# SMTP (leave empty to disable email sending)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
MAIL_FROM_ADDRESS=noreply@sidairesort.com
MAIL_FROM_NAME=Sidai Resort

# M-Pesa (Sandbox credentials)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=http://localhost:8080/api/mpesa-callback.php
MPESA_ENVIRONMENT=sandbox
